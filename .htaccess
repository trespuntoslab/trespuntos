    RewriteRule ^ux-en-ecommerce/?$ /blog/ [R=301,L]
    RewriteRule ^rediseno-web/?$ /blog/ [R=301,L]
    RewriteRule ^tendencias-ux-ui-2024/?$ /blog/ [R=301,L]
    RewriteRule ^design-system-guia-completa/?$ /blog/ [R=301,L]
    RewriteRule ^accesibilidad-web-wcag/?$ /blog/ [R=301,L]
    RewriteRule ^velocidad-web-conversion/?$ /blog/ [R=301,L]
    RewriteRule ^atomic-design-metodologia/?$ /blog/ [R=301,L]
    RewriteRule ^prototipado-rapido-figma/?$ /blog/ [R=301,L]
    RewriteRule ^microinteracciones-ux/?$ /blog/ [R=301,L]
    RewriteRule ^headless-cms-ventajas/?$ /blog/ [R=301,L]
    RewriteRule ^seo-tecnico-desarrolladores/?$ /blog/ [R=301,L]

    # WordPress categories & authors
    RewriteRule ^category/(.*)$ /blog/ [R=301,L]
    RewriteRule ^author/(.*)$ /nosotros/ [R=301,L]

    # --- Forms antiguos → nuevos ---
    RewriteRule ^gracias/?$ /form-v3/gracias [R=301,L]
    RewriteRule ^form-v3/form-step1\.html$ /iniciar-proyecto/ [R=301,L]

    # --- Páginas antiguas (producción WordPress) ---
    RewriteRule ^trespuntos/?$ /nosotros/ [R=301,L]
    RewriteRule ^contacto-trespuntos/?$ /contacto/ [R=301,L]
    RewriteRule ^cuentanos/?$ /contacto/ [R=301,L]
    RewriteRule ^politica-de-privacidad/?$ /politica-privacidad/ [R=301,L]

    # --- Works → Casos de negocio (específico antes de wildcard) ---
    RewriteRule ^works/cuentanos-tu-proyecto/?$ /contacto/ [R=301,L]
    RewriteRule ^works/(.+)/?$ /casos-de-negocio/ [R=301,L]
    RewriteRule ^works/?$ /casos-de-negocio/ [R=301,L]

    # --- Blog posts con fecha (WordPress date-based URLs) ---
    RewriteRule ^2018/03/07/la-experiencia-usuario-diseno-interfaz-pagina-web/?$ /blog/la-experiencia-de-usuario-y-el-diseno-de-interfaz-en-tu-pagina-web/ [R=301,L]
    RewriteRule ^2017/06/24/elaborado-con-amor/?$ /blog/blog-diseno-web-elaborado-con-amor/ [R=301,L]
    RewriteRule ^2017/06/28/pack-emprendedores/?$ /blog/ [R=301,L]
    RewriteRule ^2017/06/24/valientes-emprendedores/?$ /blog/ [R=301,L]

    # --- Catch-all: cualquier URL con fecha WordPress ---
    RewriteRule ^\d{4}/\d{2}/\d{2}/(.*)$ /blog/ [R=301,L]

    # --- Tags WordPress ---
    RewriteRule ^tag/(.*)$ /blog/ [R=301,L]

    # --- Bergedorfer (contenido huérfano WordPress) ---
    RewriteRule ^bergedorfer-(.*)$ /blog/ [R=301,L]

    # --- WordPress index.php ---
    RewriteRule ^index\.php$ / [R=301,L]

    # --- tipsuxui (sin guión, variante antigua) ---
    RewriteRule ^tipsuxui/?$ /blog/ [R=301,L]
    RewriteRule ^tipsuxui/(.+)/?$ /blog/ [R=301,L]
    RewriteRule ^tipsux-ui/?$ /blog/ [R=301,L]

    # --- Lleure (sección antigua) ---
    RewriteRule ^lleure(/.*)?$ / [R=301,L]

    # --- WordPress feeds ---
    RewriteRule ^feed(/.*)?$ /blog/ [R=301,L]
    RewriteRule ^comments/feed(/.*)?$ /blog/ [R=301,L]

    # --- Blog post feeds (post-level /feed/) ---
    RewriteRule ^(.+)/feed/?$ /blog/$1/ [R=301,L]
</IfModule>

# ── Security Headers ─────────────────────────────────────────
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# ── Caching (Performance) ───────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 2 days"

    # HTML: short cache (content changes)
    ExpiresByType text/html "access plus 1 hour"

    # CSS & JS: long cache (versioned assets)
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"

    # Images: long cache
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/avif "access plus 1 year"

    # Fonts: long cache
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
</IfModule>

# ── Compression ──────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript
    AddOutputFilterByType DEFLATE application/json text/xml application/xml
    AddOutputFilterByType DEFLATE image/svg+xml font/woff2
</IfModule>

# ── Error Pages ──────────────────────────────────────────────
ErrorDocument 404 /404.html

# ── Block sensitive files ────────────────────────────────────
<FilesMatch "\.(sql|md|rtf|bak|json)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

<Files ".htaccess">
    Order Allow,Deny
    Deny from all
</Files>
