# ============================================================
# TRES PUNTOS — Apache Configuration
# Deploy on Nominalia shared hosting
# ============================================================

# ── Force HTTPS ──────────────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Redirect HTTP → HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Enforce www
    RewriteCond %{HTTP_HOST} ^trespuntoscomunicacion\.es [NC]
    RewriteRule ^(.*)$ https://www.trespuntoscomunicacion.es/$1 [L,R=301]
</IfModule>

# ── Clean URLs ───────────────────────────────────────────────
<IfModule mod_rewrite.c>
    # Redirect .html to clean URL (except index.html direct access)
    RewriteCond %{THE_REQUEST} \s/+(.*?)\.html[\s?] [NC]
    RewriteRule ^ /%1 [R=301,L]

    # Serve clean URL → .html file (for pages not in folders)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.html -f
    RewriteRule ^(.+)$ $1.html [L]

    # Ensure trailing slash for directories serves index.html
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteCond %{REQUEST_FILENAME}/index.html -f
    RewriteRule ^(.*[^/])$ $1/ [R=301,L]
</IfModule>

# ── 301 Redirects: WordPress → New Structure ─────────────────
# Services (old WordPress URLs → new clean URLs)
<IfModule mod_rewrite.c>
    # Search Console Legacy Redirects
    RewriteRule ^servicio/desarrollo-web-a-medida-barcelona/?$ /servicios/desarrollo-web-a-medida-barcelona/ [R=301,L]
    RewriteRule ^servicio/ux-ui-barcelona/?$ /servicios/diseno-ux-ui-barcelona/ [R=301,L]
    RewriteRule ^servicio/tienda-online-barcelona/?$ /servicios/tienda-online-barcelona/ [R=301,L]

    # Old service pages
    RewriteRule ^diseno-ux-ui-barcelona/?$ /servicios/diseno-ux-ui-barcelona/ [R=301,L]
    RewriteRule ^diseno-ux-ui/?$ /servicios/diseno-ux-ui-barcelona/ [R=301,L]
    RewriteRule ^desarrollo-web-a-medida-barcelona/?$ /servicios/desarrollo-web-a-medida-barcelona/ [R=301,L]
    RewriteRule ^desarrollo-web/?$ /servicios/desarrollo-web-a-medida-barcelona/ [R=301,L]
    RewriteRule ^tienda-online-barcelona/?$ /servicios/tienda-online-barcelona/ [R=301,L]
    RewriteRule ^ecommerce/?$ /servicios/tienda-online-barcelona/ [R=301,L]
    RewriteRule ^consultoria-digital-barcelona/?$ /servicios/consultoria-digital-barcelona/ [R=301,L]
    RewriteRule ^consultoria-digital/?$ /servicios/consultoria-digital-barcelona/ [R=301,L]
    RewriteRule ^design-engineer-barcelona/?$ /servicios/design-engineer-barcelona/ [R=301,L]
    RewriteRule ^servicios/?$ /servicios/ [R=301,L]

    # Old pages
    RewriteRule ^hablamos/?$ /contacto/ [R=301,L]
    RewriteRule ^contacto-agencia-diseno-web-ux-ui-barcelona/?$ /contacto/ [R=301,L]
    RewriteRule ^sobre-nosotros/?$ /nosotros/ [R=301,L]
    RewriteRule ^quienes-somos/?$ /nosotros/ [R=301,L]
    RewriteRule ^metodologia/?$ /arquitectura-digital-conversion/ [R=301,L]
    RewriteRule ^casos-exito/?$ /casos-de-negocio/ [R=301,L]

    # Portfolio → Casos de negocio (individual + hub)
    RewriteRule ^portfolio/(.+)/?$ /casos-de-negocio/$1/ [R=301,L]
    RewriteRule ^portfolio/?$ /casos-de-negocio/ [R=301,L]

    # Services: old WordPress /servicio/ slugs missing
    RewriteRule ^servicio/consultoria-digital/?$ /servicios/consultoria-digital-barcelona/ [R=301,L]
    RewriteRule ^servicio/design-engineer-barcelona/?$ /servicios/design-engineer-barcelona/ [R=301,L]
    RewriteRule ^servicio/ia-generativa/?$ /servicios/ia-generativa-empresas/ [R=301,L]

    # Blog posts: old root URLs → /blog/ prefix
    RewriteRule ^tips-ux-ui/?$ /blog/ [R=301,L]
    RewriteRule ^tips-ux-ui/(.+)/?$ /blog/$1/ [R=301,L]

    # Blog posts con trafico (URLs raiz antiguas de WordPress)
    RewriteRule ^scope-canvas-el-punto-de-partida-de-lean-ux/?$ /blog/scope-canvas-el-punto-de-partida-de-lean-ux/ [R=301,L]
    RewriteRule ^metodologias-para-el-diseno-de-productos-digitales/?$ /blog/metodologias-para-el-diseno-de-productos-digitales/ [R=301,L]
    RewriteRule ^tendencias-de-diseno-web-2026-rendimiento-ux-y-conversion/?$ /blog/tendencias-de-diseno-web-2026-rendimiento-ux-y-conversion/ [R=301,L]
    RewriteRule ^experiencia-de-usuario-10-heuristicas-de-nielsen-para-tu-web/?$ /blog/experiencia-de-usuario-10-heuristicas-de-nielsen-para-tu-web/ [R=301,L]
    RewriteRule ^tests-de-usuarios-de-guerrilla/?$ /blog/tests-de-usuarios-de-guerrilla/ [R=301,L]
    RewriteRule ^que-es-diseno-ux/?$ /blog/que-es-diseno-ux/ [R=301,L]
    RewriteRule ^ux-en-ecommerce/?$ /blog/ux-en-ecommerce/ [R=301,L]
    RewriteRule ^rediseno-web/?$ /blog/rediseno-web/ [R=301,L]
    RewriteRule ^tendencias-ux-ui-2024/?$ /blog/tendencias-ux-ui-2024/ [R=301,L]
    RewriteRule ^design-system-guia-completa/?$ /blog/design-system-guia-completa/ [R=301,L]
    RewriteRule ^accesibilidad-web-wcag/?$ /blog/accesibilidad-web-wcag/ [R=301,L]
    RewriteRule ^velocidad-web-conversion/?$ /blog/velocidad-web-conversion/ [R=301,L]
    RewriteRule ^atomic-design-metodologia/?$ /blog/atomic-design-metodologia/ [R=301,L]
    RewriteRule ^prototipado-rapido-figma/?$ /blog/prototipado-rapido-figma/ [R=301,L]
    RewriteRule ^microinteracciones-ux/?$ /blog/microinteracciones-ux/ [R=301,L]
    RewriteRule ^headless-cms-ventajas/?$ /blog/headless-cms-ventajas/ [R=301,L]
    RewriteRule ^seo-tecnico-desarrolladores/?$ /blog/seo-tecnico-desarrolladores/ [R=301,L]

    # WordPress categories & authors
    RewriteRule ^category/(.*)$ /blog/ [R=301,L]
    RewriteRule ^author/(.*)$ /nosotros/ [R=301,L]

    # --- Forms antiguos → nuevos ---
    RewriteRule ^gracias/?$ /form-v3/gracias.html [R=301,L]
    RewriteRule ^form-v3/form-step1\.html$ /iniciar-proyecto/ [R=301,L]

    # --- Páginas antiguas (producción WordPress) ---
    RewriteRule ^trespuntos/?$ /nosotros/ [R=301,L]
    RewriteRule ^contacto-trespuntos/?$ /contacto/ [R=301,L]
    RewriteRule ^cuentanos/?$ /contacto/ [R=301,L]
    RewriteRule ^politica-de-privacidad/?$ /politica-privacidad/ [R=301,L]

    # --- Works → Casos de negocio (específico antes de wildcard) ---
    RewriteRule ^works/cuentanos-tu-proyecto/?$ /contacto/ [R=301,L]
    RewriteRule ^works/(.+)/?$ /casos-de-negocio/ [R=301,L]
    RewriteRule ^works/?$ /casos-de-negocio/ [R=301,L]

    # --- Blog posts con fecha (WordPress date-based URLs) ---
    RewriteRule ^2018/03/07/la-experiencia-usuario-diseno-interfaz-pagina-web/?$ /blog/la-experiencia-de-usuario-y-el-diseno-de-interfaz-en-tu-pagina-web/ [R=301,L]
    RewriteRule ^2017/06/24/elaborado-con-amor/?$ /blog/blog-diseno-web-elaborado-con-amor/ [R=301,L]
    RewriteRule ^2017/06/28/pack-emprendedores/?$ /blog/ [R=301,L]
    RewriteRule ^2017/06/24/valientes-emprendedores/?$ /blog/ [R=301,L]

    # --- Catch-all: cualquier URL con fecha WordPress ---
    RewriteRule ^\d{4}/\d{2}/\d{2}/(.*)$ /blog/ [R=301,L]

    # --- Tags WordPress ---
    RewriteRule ^tag/(.*)$ /blog/ [R=301,L]

    # --- Bergedorfer (contenido huérfano WordPress) ---
    RewriteRule ^bergedorfer-(.*)$ /blog/ [R=301,L]

    # --- WordPress feeds ---
    RewriteRule ^feed(/.*)?$ /blog/ [R=301,L]
    RewriteRule ^comments/feed(/.*)?$ /blog/ [R=301,L]
</IfModule>

# ── Security Headers ─────────────────────────────────────────
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# ── Caching (Performance) ───────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 2 days"

    # HTML: short cache (content changes)
    ExpiresByType text/html "access plus 1 hour"

    # CSS & JS: long cache (versioned assets)
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"

    # Images: long cache
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/avif "access plus 1 year"

    # Fonts: long cache
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
</IfModule>

# ── Compression ──────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript
    AddOutputFilterByType DEFLATE application/json text/xml application/xml
    AddOutputFilterByType DEFLATE image/svg+xml font/woff2
</IfModule>

# ── Error Pages ──────────────────────────────────────────────
ErrorDocument 404 /404.html

# ── Block sensitive files ────────────────────────────────────
<FilesMatch "\.(sql|md|rtf|bak|json)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

<Files ".htaccess">
    Order Allow,Deny
    Deny from all
</Files>
